# OneOps 后端环境变量配置示例
# 说明：复制此文件为 .env 并修改配置
# 注意：生产环境必须修改默认密码和密钥

# 配置文件路径（可选，指定config.yaml的路径）
# CONFIG_PATH=config.yaml

# 服务器配置
SERVER_PORT=8082
GIN_MODE=debug

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=oneops

# JWT配置（生产环境必须使用强随机密钥）
JWT_SECRET=your_jwt_secret_key_change_in_production_please_use_long_random_string

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log
