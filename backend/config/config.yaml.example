# OneOps 后端配置文件
# 说明：这是配置文件的示例模板，实际部署时请复制为 config.yaml 并修改配置

# 服务器配置
server:
  port: "8082"              # HTTP服务监听端口
  mode: "debug"             # 运行模式: debug, release, test
  read_timeout: 60          # 读取超时时间(秒)
  write_timeout: 60         # 写入超时时间(秒)

# 数据库配置
database:
  host: "localhost"         # 数据库主机地址
  port: "3306"              # 数据库端口
  user: "root"              # 数据库用户名
  password: "${DB_PASSWORD}" # 数据库密码(从环境变量读取)
  dbname: "oneops"          # 数据库名称
  max_idle_conns: 10        # 最大空闲连接数
  max_open_conns: 100       # 最大打开连接数
  log_level: "warn"         # GORM日志级别: silent, error, warn, info

# JWT认证配置
jwt:
  secret: "${JWT_SECRET}"   # JWT密钥(从环境变量读取，生产环境必须修改)
  expire_time: 24           # Token过期时间(小时)
  issuer: "oneops"          # JWT签发者

# 日志配置
log:
  level: "debug"            # 日志级别: debug, info, warn, error, fatal
  filename: "logs/app.log"  # 日志文件路径
  max_size: 100             # 单个日志文件最大大小(MB)
  max_backups: 3            # 保留的旧日志文件最大数量
  max_age: 28               # 保留旧日志文件的最大天数
  compress: true            # 是否压缩旧日志文件

# CORS跨域配置
cors:
  allow_origins:            # 允许的源地址
    - "http://localhost:5173"
    - "http://localhost:3000"
  allow_methods:            # 允许的HTTP方法
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "OPTIONS"
  allow_headers:            # 允许的请求头
    - "Origin"
    - "Content-Type"
    - "Authorization"
    - "X-Requested-With"
  expose_headers:           # 暴露的响应头
    - "Content-Length"
    - "Content-Type"
  max_age: 86400            # 预检请求缓存时间(秒)
  allow_credentials: true   # 是否允许携带凭证

# 应用配置
app:
  name: "OneOps"            # 应用名称
  version: "1.0.0"          # 应用版本
  environment: "development" # 运行环境: development, staging, production
  debug: true               # 是否开启调试模式
